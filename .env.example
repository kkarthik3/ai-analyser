# ============================================================
# AI-Bot Options Intelligence Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- FYERS API ----
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
FYERS_ACCESS_TOKEN=
FYERS_REFRESH_TOKEN=

# ---- PostgreSQL + TimescaleDB ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aibot
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=options_intel
DATABASE_URL=postgresql+asyncpg://aibot:change_this_password@postgres:5432/options_intel

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Groq AI ----
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Alerts: Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Alerts: Discord ----
DISCORD_WEBHOOK_URL=

# ---- Alerts: Email ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ---- Application ----
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ---- Market Config ----
WATCHLIST_INDICES=NSE:NIFTY50-INDEX,NSE:NIFTYBANK-INDEX,NSE:FINNIFTY-INDEX,BSE:SENSEX-INDEX
WATCHLIST_STOCKS=NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:HDFCBANK-EQ,NSE:INFY-EQ,NSE:ICICIBANK-EQ
OPTION_CHAIN_STRIKE_COUNT=20
DATA_BUFFER_MS=100
OPTION_CHAIN_POLL_INTERVAL_S=3
